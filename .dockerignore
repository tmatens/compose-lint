__pycache__
*.pyc
*.pyo
*.egg-info
dist/
build/
.venv/
venv/
ENV/
mutants/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.nox/
.coverage
htmlcov/
.claude/
.vscode/
.idea/
.env
.env.*
!.env.example
.DS_Store
Thumbs.db
*.swp
*.swo
*~
compose-lint-plan.md
